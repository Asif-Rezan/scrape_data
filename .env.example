MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=product_data

# Jobs are stored separately from the phone catalog.
JOBS_MYSQL_DATABASE=jobs_data

# Chakrie publisher (copy the real token into .env, never commit it)
CHAKRIE_API_TOKEN=replace_with_your_bearer_token
CHAKRIE_API_URL=https://www.chakrie.com/api/v1/mobile/employer/jobs
CHAKRIE_TIMELINE_API_URL=https://www.chakrie.com/api/v1/mobile/timeline/posts/create

# Reddit timeline source. RSS supports at most 100 entries per request.
REDDIT_URL=https://www.reddit.com/r/jobhunting/
REDDIT_FETCH_LIMIT=100
REDDIT_POST_LIMIT=100

# Be polite to the source website.
SCRAPE_DELAY_SECONDS=1.5
REQUEST_TIMEOUT_SECONDS=30
